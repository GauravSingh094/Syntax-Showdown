# Syntax Showdown - Backend Environment Template

# Ollama Config
OLLAMA_URL=http://localhost:11434

# Clerk Authentication (Required for JWT Verification)
# Find these in your Clerk Dashboard > API Keys
CLERK_SECRET_KEY=your_clerk_secret_key_here
CLERK_JWKS_URL=https://your-app-id.clerk.accounts.dev/.well-known/jwks.json

# ChromaDB Cloud (Vector Storage for History)
# Find these in your Chroma Dashboard
CHROMA_HOST=api.trychroma.com
CHROMA_API_KEY=your_chroma_api_key_here
CHROMA_TENANT=your_chroma_tenant_id_here
CHROMA_DATABASE=Syntax-Showdown
