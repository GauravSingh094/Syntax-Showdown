# Syntax Showdown - Unified Master Gitignore

# === NEXT.JS / FRONTEND ===
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
frontend/.vercel
frontend/*.tsbuildinfo
frontend/next-env.d.ts

# Package manager artifacts
frontend/.pnp
frontend/.pnp.*
frontend/.yarn/*
!frontend/.yarn/patches
!frontend/.yarn/plugins
!frontend/.yarn/releases
!frontend/.yarn/versions
frontend/.pnpm-debug.log*

# === FASTAPI / BACKEND ===
backend/venv/
backend/__pycache__/
backend/*.pyc
backend/*.pyo
backend/*.pyd
backend/.pytest_cache/
backend/.ipynb_checkpoints/
backend/app/__pycache__/

# === ENVIRONMENT & SECRETS (CRITICAL) ===
.env
.env.local
.env.*.local
backend/.env
frontend/.env.local
frontend/.env
*.pem
*.key

# === SYSTEM / IDE ===
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# === LOGS & CACHE ===
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.eslintcache

# === DATABASES ===
backend/chroma_db/
backend/data/
**/__pycache__
